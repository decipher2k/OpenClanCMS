+function cs_hash_equals($known, $given) {
+
+  if(function_exists('hash_equals'))
+    return hash_equals((string) $known, (string) $given);
+
+  $known = (string) $known;
+  $given = (string) $given;
+  if(strlen($known) !== strlen($given))
+    return false;
+
+  $result = 0;
+  for($run = 0; $run < strlen($known); $run++)
+    $result |= ord($known{$run}) ^ ord($given{$run});
+
+  return $result === 0;
+}
+
+function cs_random_string($length = 32) {
+
+  $length = (int) $length;
+  if($length < 1)
+    $length = 32;
+
+  $bytes = '';
+  if(function_exists('random_bytes')) {
+    try {
+      $bytes = random_bytes($length);
+    }
+    catch(Exception $e) {
+      $bytes = '';
+    }
+  }
+  if($bytes === '' AND function_exists('openssl_random_pseudo_bytes')) {
+    $strong = false;
+    $bytes = openssl_random_pseudo_bytes($length, $strong);
+    if(empty($strong))
+      $bytes = '';
+  }
+
+  if($bytes === '') {
+    for($run = 0; $run < $length; $run++)
+      $bytes .= chr(mt_rand(0, 255));
+  }
+
+  return substr(bin2hex($bytes), 0, $length);
+}
+
+function cs_xsrf_key($new = 0) {
+
+  if(session_id() === '')
+    return '';
+
+  if(!isset($_SESSION['cs_xsrf_keys']) OR !is_array($_SESSION['cs_xsrf_keys']))
+    $_SESSION['cs_xsrf_keys'] = array();
+
+  if(empty($new) AND !empty($_SESSION['cs_xsrf_keys']))
+    return end($_SESSION['cs_xsrf_keys']);
+
+  $key = cs_random_string(40);
+  $_SESSION['cs_xsrf_keys'][] = $key;
+
+  if(count($_SESSION['cs_xsrf_keys']) > 25)
+    $_SESSION['cs_xsrf_keys'] = array_slice($_SESSION['cs_xsrf_keys'], -25);
+
+  return $key;
+}
+
+function cs_xsrf_needs_get_key($params, $mod = 0, $action = 0) {
+
+  global $cs_main;
+  $dangerous = array(
+    'active' => 1,
+    'activate' => 1,
+    'agree' => 1,
+    'clear' => 1,
+    'confirm' => 1,
+    'deactive' => 1,
+    'del' => 1,
+    'delete' => 1,
+    'delabo' => 1,
+    'delall' => 1,
+    'del_id' => 1,
+    'done' => 1,
+    'fix' => 1,
+    'hide' => 1,
+    'newabo' => 1,
+    'turn' => 1,
+    'unhide' => 1
+  );
+
+  if(empty($mod) AND isset($cs_main['mod']))
+    $mod = $cs_main['mod'];
+  if(empty($action) AND isset($cs_main['action']))
+    $action = $cs_main['action'];
+
+  if(is_array($params)) {
+    if($mod == 'board' AND $action == 'sort' AND (isset($params['board']) OR isset($params['cat'])))
+      return true;
+
+    if($mod == 'board' AND $action == 'reportdone' AND isset($params['id']))
+      return true;
+
+    if($mod == 'messages' AND $action == 'archiv' AND isset($params['id']))
+      return true;
+
+    if($mod == 'wars' AND $action == 'rounds' AND (isset($params['up']) OR isset($params['down'])))
+      return true;
+
+    foreach($params AS $key => $value) {
+      if(isset($dangerous[$key]))
+        return true;
+    }
+    return false;
+  }
+
+  $params = str_replace('&amp;', '&', (string) $params);
+  if($mod == 'board' AND $action == 'sort' AND preg_match('=(^|[&/])(board|cat)(=|/)=i', $params))
+    return true;
+
+  if($mod == 'board' AND $action == 'reportdone' AND preg_match('=(^|[&/])id(=|/)=i', $params))
+    return true;
+
+  if($mod == 'messages' AND $action == 'archiv' AND preg_match('=(^|[&/])id(=|/)=i', $params))
+    return true;
+
+  if($mod == 'wars' AND $action == 'rounds' AND preg_match('=(^|[&/])(up|down)(=|/)=i', $params))
+    return true;
+
+  foreach($dangerous AS $key => $value) {
+    if(preg_match('=(^|[&/])' . preg_quote($key, '=') . '($|[=/&])=i', $params))
+      return true;
+  }
+
+  return false;
+}
+
+function cs_xsrf_url_more($more, $mod = 0, $action = 0) {
+
+  global $cs_main;
+
+  if(empty($more) OR empty($cs_main['xsrf_protection']) OR !cs_xsrf_needs_get_key($more, $mod, $action))
+    return $more;
+
+  if(strpos(str_replace('&amp;', '&', (string) $more), 'cs_xsrf_key=') !== false)
+    return $more;
+
+  $key = cs_xsrf_key();
+  if(empty($key))
+    return $more;
+
+  return $more . '&amp;cs_xsrf_key=' . rawurlencode($key);
+}
+
+function cs_safe_filename($filename) {
+
+  $filename = basename(str_replace('\\', '/', (string) $filename));
+  $filename = preg_replace("=[^a-z0-9._-]=i", '_', $filename);
+  $filename = trim($filename, '._');
+
+  return empty($filename) ? false : $filename;
+}
+
+function cs_safe_path($base, $path, $must_exist = 0) {
+
+  $base_real = realpath($base);
+  if($base_real === false)
+    return false;
+
+  $path = str_replace('\\', '/', (string) $path);
+  $path = preg_replace("=/+=", '/', $path);
+  $target = rtrim($base_real, '\\/') . '/' . ltrim($path, '/');
+  $target_real = realpath($target);
+
+  if($target_real === false) {
+    if(!empty($must_exist))
+      return false;
+
+    $parent_real = realpath(dirname($target));
+    if($parent_real === false)
+      return false;
+    $target_real = rtrim($parent_real, '\\/') . '/' . basename($target);
+  }
+
+  $base_cmp = strtolower(str_replace('\\', '/', rtrim($base_real, '\\/') . '/'));
+  $target_cmp = strtolower(str_replace('\\', '/', $target_real));
+  if(strpos($target_cmp . (is_dir($target_real) ? '/' : ''), $base_cmp) !== 0)
+    return false;
+
+  return $target_real;
+}
+
+function cs_jsquote($value) {
+
+  return str_replace(array("\\", "'", "\r", "\n", '</'), array("\\\\", "\\'", "\\r", "\\n", '<\/'), (string) $value);
+}
+
+function cs_clean_url_part($url) {
+
+  $url = trim(str_replace(array("\r", "\n", "\0"), '', (string) $url));
+  $url = preg_replace("=^https?://=i", '', $url);
+  $url = str_replace(array('"', "'", '<', '>'), '', $url);
+
+  return $url;
+}
